const EGGS_IMG    = 'https://lh3.googleusercontent.com/aida-public/AB6AXuC-UsSIJ6sfVDO2-UFhiR60M2KqHr0rFJB958rkPne3sXhcSaaRJYcOVJOChdGPMBzo8aVsIIp6Nhs_K1gt6BRPwQlo4bx21idZS3FgBZ8LPvl6gQecxs0q_4BwXBW1qb1hX0ir7EkCYvGq6Yz93Ox4Yy64rv2h3-4F__glD8Hnhu7XoS3HmkO6DSQeCWmkSuqoaDPWONHigeYZhhYTAFRQVVetnr9F2ioTKKgPlNQkTR9HiR9ZA7qTQ8lbnSdgTmr1q4gNExFEpEw';
const CREPES_IMG  = 'https://lh3.googleusercontent.com/aida-public/AB6AXuBGLb5zu9YvehEDbjiQT95abjFdqAJ0sADRR3goTeVm1qFC1wZgEN3vOwjH6zJ6dgz2TVAXL0gcbCbQmJIQ9PS1ST9tRrowEtVNCL4HqArnFhTzw0LPmRi7s5ivlED37HoS4Ktfjiz1KrEpU_CDP6xbKqbXU4z_xqb6Q78tg91Qs286HNzBtBcoD0IdF1JJGVC-ZLZm8x3bjIJflWI7MKYrKVHs9lipZX01j6W6JljA-ImIStCVvu7Q4Bz4GARAb9doQ9qC0Qc_ypc';
const SKILLET_IMG = 'https://lh3.googleusercontent.com/aida-public/AB6AXuDegpkxj7cGBVnn8gZWr6OUpH9irIogrWNr1NdawqOlDLJzmWArV0CH6jLXdL7RQe3Y5MyWt3kTk6KZ3EGP4gxnSupSLcW6oXRHi9vtVdf4WnWHP7tN2ZAFqPBuv-GbGGT0Qd0_CXDa7vNRBOmfSYH_dKPlKo4hq8C9sExnQRFU2ya-1nQzDzQDJ7k9j-ZvNtA0kWG5LXlEttB-NNTMvwy12B_VtUbGm8FkAB6b7mF1jS-7q18BauOwJieU_hJi_LkWxF89xVHbwI4';
const ABOUT_IMG   = 'https://lh3.googleusercontent.com/aida-public/AB6AXuCsOP5BoPbPkfUvYwC_JjfXGutlJDXj3e6YtP_c1-jNrNH9PZhIYLGwjJc-obrZdiaqeGSBnWWvJXA6iEtR3bLENCvrhXaO-VSYsI0KmxEr6bMuk8cUY6Y-lEXdbkaIqHv5nO3-jG0o1PlatwViWlIbG1OoBK08Qv8_aerKoG5CTg95wiUiX52tnVHb2ARKw15H9q4FWetFQCyqAKt7Cr0HN6IzsYG_ftNM8sr7mSyEPW7kJ9xOrlKy84UoHm9anatv46NjD_Z5VGY';
---

<Layout
  title="Burleson Brunch House — A Taste of Home in Every Bite"
  description="Family-owned brunch restaurant in Burleson, TX. Fresh, homemade food open daily 7am–3pm at 2650 SW Wilshire Blvd. Texas Eggs Benedict, house skillets, and more."
>

  <!-- ═══════════════════════════════════════
       HERO
  ═══════════════════════════════════════ -->
  <header class="relative h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        class="w-full h-full object-cover"
        src={HERO_IMG}
        alt="Stack of golden buttermilk pancakes with maple syrup being poured over the top — Burleson Brunch House"
        style="object-position: center 30%;"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/20 to-black/50"></div>
    </div>

    <div class="relative z-10 text-center text-white px-4 max-w-4xl mx-auto">
      <h1 class="font-script text-5xl sm:text-7xl md:text-9xl mb-4 drop-shadow-lg leading-tight">
        Burleson Brunch House
      </h1>
      <p class="font-headline italic text-xl sm:text-2xl md:text-4xl mb-8 tracking-wide drop-shadow-md">
        A Taste of Home in Every Bite
      </p>
      <div class="inline-flex items-center gap-3 bg-white/10 backdrop-blur-md px-8 py-3 rounded-full border border-white/20">
        <span class="material-symbols-outlined text-lg">schedule</span>
        <span class="font-label uppercase tracking-[0.18em] text-sm">Open Daily · 7 am – 3 pm</span>
      </div>
    </div>

    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 text-white/80 animate-bounce">
      <span class="material-symbols-outlined text-4xl">keyboard_double_arrow_down</span>
    </div>
  </header>


  <!-- ═══════════════════════════════════════
       FEATURED DISHES — bento editorial grid
  ═══════════════════════════════════════ -->
  <section class="py-14 md:py-24 bg-surface fade-in-section" aria-label="Featured dishes">
    <div class="max-w-7xl mx-auto px-6 md:px-8">

      <div class="mb-16 text-center">
        <p class="font-label uppercase tracking-[0.2em] text-sm text-tertiary mb-3">From Our Kitchen</p>
        <h2 class="font-headline text-4xl md:text-5xl italic text-primary mb-3">Our House Favorites</h2>
        <div class="h-0.5 w-20 bg-tertiary/30 mx-auto rounded-full"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-stretch">

        <!-- Main Feature — Eggs Benedict -->
        <article class="md:col-span-7 group relative overflow-hidden rounded-xl editorial-shadow bg-surface-container-low border border-primary/10">
          <div class="aspect-[16/9] overflow-hidden">
            <img
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              src="/eggs-benedict.jpg"
              alt="Eggs Benedict — two poached eggs with hollandaise sauce served at Burleson Brunch House"
              loading="lazy"
            />
          </div>
          <div class="p-8">
            <span class="text-tertiary font-bold tracking-widest text-xs uppercase mb-2 block">Signature Dish</span>
            <h3 class="font-headline text-3xl mb-3 text-on-surface">Eggs Benedict</h3>
            <p class="text-on-surface-variant max-w-md leading-relaxed">
              Poached eggs on a jalapeño-cheddar biscuit with smoked brisket and our house hollandaise. A Texas spin on a classic that people keep coming back for.
            </p>
          </div>
        </article>

        <!-- Side stack -->
        <div class="md:col-span-5 flex flex-col gap-6">

          <!-- Greek Salad -->
          <article class="flex-1 group relative overflow-hidden rounded-xl editorial-shadow bg-surface-container-low border border-primary/10 flex flex-col">
            <div class="h-48 overflow-hidden">
              <img
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                src="/greek-salad.jpg"
                alt="Greek Salad — fresh greens with grilled chicken, tomatoes, cucumbers, strawberries, and house dressing at Burleson Brunch House"
                loading="lazy"
              />
            </div>
            <div class="p-6">
              <h3 class="font-headline text-2xl mb-2 text-on-surface">Greek Salad</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed">
                Fresh mixed greens with grilled chicken, tomatoes, cucumbers, and house dressing. Light, fresh, and made to order.
              </p>
            </div>
          </article>

          <!-- Banana Nutella French Toast -->
          <article class="flex-1 group relative overflow-hidden rounded-xl editorial-shadow bg-surface-container-low border border-primary/10 flex flex-col">
            <div class="h-48 overflow-hidden">
              <img
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                src="/nutella-french-toast.jpg"
                alt="Banana Nutella French Toast — thick french toast stacked with Nutella, banana, chocolate drizzle, and whipped cream"
                loading="lazy"
              />
            </div>
            <div class="p-6">
              <h3 class="font-headline text-2xl mb-2 text-on-surface">Banana Nutella French Toast</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed">
                Thick french toast loaded with Nutella, banana, chocolate drizzle, and fresh whipped cream. A crowd favorite.
              </p>
            </div>
          </article>

        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════
       ABOUT — Feature Overlap section
  ═══════════════════════════════════════ -->
  <section class="py-14 md:py-24 bg-surface-container overflow-hidden fade-in-section" aria-label="About us">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">

        <!-- Image side -->
        <div class="relative order-2 md:order-1">
          <div class="absolute -top-12 -left-12 w-72 h-72 bg-primary-container rounded-full opacity-25 blur-3xl pointer-events-none"></div>
          <div class="relative z-10 rounded-xl overflow-hidden editorial-shadow transform -rotate-2">
            <img
              class="w-full h-[480px] object-cover"
              src={ABOUT_IMG}
              alt="Warm restaurant interior at Burleson Brunch House — sunlit wooden tables, sage green walls, and vintage family photos"
              loading="lazy"
            />
          </div>
          <!-- Floating accent badge -->
          <div class="hidden sm:block absolute -bottom-5 -right-4 z-20 bg-surface-container-lowest rounded-xl px-5 py-4 editorial-shadow border border-outline-variant/15">
            <p class="text-xs uppercase tracking-widest text-on-surface-variant mb-1">Open Daily</p>
            <p class="font-headline italic text-primary text-xl">7 am – 3 pm</p>
          </div>
        </div>

        <!-- Text side -->
        <div class="order-1 md:order-2">
          <p class="font-label uppercase tracking-[0.2em] text-sm text-tertiary mb-4">Our Story</p>
          <h2 class="font-headline text-4xl md:text-6xl italic text-primary leading-tight mb-8">
            From Our Family<br />to Yours
          </h2>
          <div class="space-y-5 text-on-surface-variant leading-relaxed text-lg">
            <p>
              We've been cooking breakfast and lunch in Burleson for years now. This place started as a family operation and has stayed that way. From day one, we've cared about doing things right.
            </p>
            <p>
              We get our eggs, bacon, and produce from local Texas farms whenever we can. Fresh ingredients make a difference you can actually taste. We're glad you're here.
            </p>
          </div>
          <div class="mt-10 font-script text-4xl text-tertiary">
            The Burleson Brunch House Family
          </div>
          <div class="mt-8">
            <a
              href="/about"
              class="inline-flex items-center gap-2 text-primary font-medium border-b-2 border-primary/30 hover:border-primary pb-1 transition-all duration-300"
            >
              Read our full story
              <span class="material-symbols-outlined text-base">arrow_forward</span>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════
       MENU PREVIEW — Tonal transition
  ═══════════════════════════════════════ -->
  <section class="py-14 md:py-24 bg-surface-container-low fade-in-section" aria-label="Menu preview">
    <div class="max-w-3xl mx-auto px-6 md:px-8">

      <div class="text-center mb-14">
        <p class="font-label uppercase tracking-[0.2em] text-sm text-tertiary mb-3">A Sample of What Awaits</p>
        <h2 class="font-headline text-3xl md:text-5xl italic text-primary">Signature Menu Highlights</h2>
      </div>

      <div class="space-y-0">
        <!-- Texas Eggs Benedict -->
        <div class="group py-7 border-b border-outline-variant/20">
          <div class="flex items-start justify-between gap-6">
            <div class="flex-1">
              <h3 class="font-headline text-2xl text-on-surface group-hover:text-tertiary transition-colors duration-300 mb-2">
                Texas Eggs Benedict
              </h3>
              <p class="text-on-surface-variant italic text-sm leading-relaxed">
                Poached eggs on jalapeño-cheddar biscuits with slow-smoked brisket and house hollandaise.
              </p>
            </div>
            <span class="text-tertiary font-bold text-lg whitespace-nowrap mt-0.5">$14.99</span>
          </div>
        </div>

        <!-- Triple Berry Crepes -->
        <div class="group py-7 border-b border-outline-variant/20">
          <div class="flex items-start justify-between gap-6">
            <div class="flex-1">
              <h3 class="font-headline text-2xl text-on-surface group-hover:text-tertiary transition-colors duration-300 mb-2">
                Triple Berry Crepes
              </h3>
              <p class="text-on-surface-variant italic text-sm leading-relaxed">
                Three thin crepes with fresh strawberries, blueberries, raspberries, whipped cream, and house compote.
              </p>
            </div>
            <span class="text-tertiary font-bold text-lg whitespace-nowrap mt-0.5">$12.99</span>
          </div>
        </div>

        <!-- Burleson Skillet -->
        <div class="group py-7 border-b border-outline-variant/20">
          <div class="flex items-start justify-between gap-6">
            <div class="flex-1">
              <h3 class="font-headline text-2xl text-on-surface group-hover:text-tertiary transition-colors duration-300 mb-2">
                Burleson Skillet
              </h3>
              <p class="text-on-surface-variant italic text-sm leading-relaxed">
                Home fries, house sausage, peppers, onions, two eggs any style, and melted cheddar in a sizzling cast iron.
              </p>
            </div>
            <span class="text-tertiary font-bold text-lg whitespace-nowrap mt-0.5">$13.99</span>
          </div>
        </div>

        <!-- Summer Skillet -->
        <div class="group py-7">
          <div class="flex items-start justify-between gap-6">
            <div class="flex-1">
              <h3 class="font-headline text-2xl text-on-surface group-hover:text-tertiary transition-colors duration-300 mb-2">
                Summer Skillet
              </h3>
              <p class="text-on-surface-variant italic text-sm leading-relaxed">
                Sweet potato hash with roasted corn, jalapeño, cotija cheese, two eggs, and a drizzle of smoky chipotle crema.
              </p>
            </div>
            <span class="text-tertiary font-bold text-lg whitespace-nowrap mt-0.5">$13.99</span>
          </div>
        </div>
      </div>

      <div class="mt-14 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/menu"
          class="inline-flex items-center justify-center gap-2 bg-primary text-on-primary px-10 py-4 rounded-xl text-lg font-medium editorial-shadow hover:scale-105 hover:opacity-90 transition-all duration-300"
        >
          View Full Menu
        </a>
        <a
          href="/order"
          class="inline-flex items-center justify-center gap-2 border-2 border-primary text-primary px-10 py-4 rounded-xl text-lg font-medium hover:bg-primary hover:text-on-primary transition-all duration-300"
        >
          <span class="material-symbols-outlined text-base">shopping_bag</span>
          Order Online
        </a>
      </div>

    </div>
  </section>


  <!-- ═══════════════════════════════════════
       VISIT US
  ═══════════════════════════════════════ -->
  <section class="py-14 md:py-24 bg-surface overflow-hidden fade-in-section" aria-label="Location and hours">
    <div class="max-w-7xl mx-auto px-6 md:px-8">

      <div class="text-center mb-14">
        <h2 class="font-headline text-4xl md:text-5xl italic text-primary">Come Visit Us</h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 rounded-3xl overflow-hidden editorial-shadow border border-outline-variant/15">

        <!-- Info panel -->
        <div class="bg-surface-container-highest p-10 md:p-16">
          <h3 class="font-headline text-4xl italic text-primary mb-10">We'd Love to See You</h3>

          <div class="space-y-8">
            <div class="flex items-start gap-4">
              <span class="material-symbols-outlined text-tertiary mt-0.5">location_on</span>
              <div>
                <h4 class="font-semibold text-on-surface mb-1">Address</h4>
                <p class="text-on-surface-variant leading-relaxed">
                  2650 SW Wilshire Blvd<br />Burleson, TX 76028
                </p>
                <a
                  href="https://maps.google.com/?q=2650+SW+Wilshire+Blvd+Burleson+TX+76028"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-primary hover:underline mt-1 inline-block transition-colors duration-300"
                >
                  Get directions →
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <span class="material-symbols-outlined text-tertiary mt-0.5">schedule</span>
              <div>
                <h4 class="font-semibold text-on-surface mb-1">Hours</h4>
                <p class="text-on-surface-variant">Monday – Sunday<br />7:00 am – 3:00 pm</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <span class="material-symbols-outlined text-tertiary mt-0.5">call</span>
              <div>
                <h4 class="font-semibold text-on-surface mb-1">Phone</h4>
                <a
                  href="tel:6827301391"
                  class="text-on-surface-variant hover:text-primary transition-colors duration-300"
                >
                  (682) 730-1391
                </a>
              </div>
            </div>
          </div>

          <div class="mt-10">
            <a
              href="/contact"
              class="inline-flex items-center gap-2 bg-primary text-on-primary px-8 py-3 rounded-xl font-medium hover:opacity-85 transition-opacity duration-300 editorial-shadow"
            >
              <span class="material-symbols-outlined text-base">event_available</span>
              Reserve a Table
            </a>
          </div>
        </div>

        <!-- Google Maps embed -->
        <div class="h-72 lg:h-auto min-h-[380px]">
          <iframe
            src="https://maps.google.com/maps?q=2650+SW+Wilshire+Blvd+Burleson+TX+76028&output=embed"
            width="100%"
            height="100%"
            style="border:0; min-height: 380px;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Burleson Brunch House location on Google Maps"
          ></iframe>
        </div>

      </div>
    </div>
  </section>

</Layout>
