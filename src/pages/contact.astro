---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact & Hours — Burleson Brunch House"
  description="Find Burleson Brunch House in Burleson, TX. Open daily 7am–3pm at 2650 SW Wilshire Blvd. Call us at (682) 730-1391."
>

  <!-- ═══════════════════════════════════════
       PAGE HEADER
  ═══════════════════════════════════════ -->
  <div class="pt-28 pb-14 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-6 md:px-8 text-center">
      <p class="font-label uppercase tracking-[0.2em] text-sm text-tertiary mb-3">We'd Love to See You</p>
      <h1 class="font-headline text-5xl md:text-6xl italic text-primary">Come Find Us</h1>
    </div>
  </div>


  <!-- ═══════════════════════════════════════
       MAIN CONTENT
  ═══════════════════════════════════════ -->
  <section class="py-12 md:py-20 bg-surface fade-in-section">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

        <!-- Info panel -->
        <div class="space-y-6">

          <!-- Phone -->
          <div class="bg-surface-container-low rounded-2xl p-8 editorial-shadow border border-primary/10">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-primary-container flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-primary">call</span>
              </div>
              <div>
                <h2 class="font-headline text-2xl italic text-primary mb-1">Give Us a Call</h2>
                <p class="text-on-surface-variant text-sm mb-3">The fastest way to reach us. We're happy to answer questions or hold a table for large groups.</p>
                <a
                  href="tel:6827301391"
                  class="inline-flex items-center gap-2 bg-primary text-on-primary px-6 py-3 rounded-xl font-medium editorial-shadow hover:opacity-85 transition-opacity duration-300 text-lg"
                >
                  (682) 730-1391
                </a>
              </div>
            </div>
          </div>

          <!-- Hours -->
          <div class="bg-surface-container-low rounded-2xl p-8 editorial-shadow border border-primary/10">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-primary-container flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-primary">schedule</span>
              </div>
              <div>
                <h2 class="font-headline text-2xl italic text-primary mb-1">Hours</h2>
                <p class="text-on-surface text-lg font-medium">Monday – Sunday</p>
                <p class="text-on-surface-variant">7:00 am – 3:00 pm</p>
                <p class="text-xs text-on-surface-variant/70 mt-2">Kitchen closes at 2:30 pm. Walk-ins always welcome.</p>
              </div>
            </div>
          </div>

          <!-- Address -->
          <div class="bg-surface-container-low rounded-2xl p-8 editorial-shadow border border-primary/10">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-primary-container flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-primary">location_on</span>
              </div>
              <div>
                <h2 class="font-headline text-2xl italic text-primary mb-1">Address</h2>
                <p class="text-on-surface-variant leading-relaxed mb-3">
                  2650 SW Wilshire Blvd<br />Burleson, TX 76028
                </p>
                <a
                  href="https://maps.google.com/?q=2650+SW+Wilshire+Blvd+Burleson+TX+76028"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1 text-sm text-primary hover:underline"
                >
                  <span class="material-symbols-outlined text-sm">open_in_new</span>
                  Open in Google Maps
                </a>
              </div>
            </div>
          </div>

        </div>

        <!-- Map -->
        <div class="space-y-6">
          <div class="rounded-2xl overflow-hidden editorial-shadow h-80 md:h-[480px]">
            <iframe
              src="https://maps.google.com/maps?q=2650+SW+Wilshire+Blvd+Burleson+TX+76028&output=embed"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Burleson Brunch House location on Google Maps"
            ></iframe>
          </div>
          <p class="text-center text-on-surface-variant text-sm">
            Plenty of parking right out front. Come hungry.
          </p>
        </div>

      </div>
    </div>
  </section>

</Layout>
