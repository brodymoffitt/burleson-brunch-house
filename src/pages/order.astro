  name: string; price: string;
  sidesRequired?: number;
  sidesPool?: SideOption[];    // item-level side options (overrides section.sidesPool)
  upgrades?: SectionUpgrade[]; // item-level upgrades (overrides section.upgrades)
  upgradeLabel?: string;
  upgradeIcon?: string;
};
type MenuSection    = {
  id: string; category: string; icon: string; items: MenuItem[];
  sidesPool?: SideOption[];    // section-level side options (fallback to breakfastSides)
