---

<Layout
  title="Menu — Burleson Brunch House"
  description="Full breakfast and lunch menu at Burleson Brunch House in Burleson, TX. Benedicts, skillets, crepes, sandwiches, burgers, and more. Open daily 7am–3pm."
>

  <!-- ═══════════════════════════════════════
       MENU HERO
  ═══════════════════════════════════════ -->
  <header class="relative h-64 md:h-80 flex items-end overflow-hidden" style="padding-top: 80px;">
    <div class="absolute inset-0 z-0">
      <img
        class="w-full h-full object-cover object-center"
        src={HERO_IMG}
        alt="Top-down view of a beautiful brunch spread — the menu at Burleson Brunch House"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/35 to-black/20"></div>
    </div>
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 md:px-8 pb-10 md:pb-12">
      <p class="font-label uppercase tracking-[0.2em] text-sm text-white/70 mb-2">Burleson Brunch House</p>
      <h1 class="font-headline text-5xl md:text-7xl italic text-white drop-shadow-lg">Our Menu</h1>
    </div>
  </header>


  <!-- ═══════════════════════════════════════
       INFO STRIP
  ═══════════════════════════════════════ -->
  <div class="bg-primary">
    <div class="max-w-7xl mx-auto px-6 md:px-8 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
      <p class="text-on-primary/90 text-sm">
        All items made fresh to order · Gluten-free options available · Ask about daily specials
      </p>
      <div class="flex items-center gap-2 text-on-primary font-medium text-sm whitespace-nowrap">
        <span class="material-symbols-outlined text-sm">schedule</span>
        Open Daily · 7:00 am – 3:00 pm
      </div>
    </div>
  </div>


  <!-- ═══════════════════════════════════════
       TAB BAR — sticky below nav
  ═══════════════════════════════════════ -->
  <div class="sticky top-[72px] z-40 bg-surface/95 backdrop-blur-md border-b border-outline-variant/20 shadow-[0_2px_12px_rgba(57,56,47,0.05)]">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="flex gap-1 py-3 overflow-x-auto scrollbar-hide" role="tablist" aria-label="Menu sections">
        {tabs.map((tab, i) => (
          <button
            id={`tab-btn-${tab.id}`}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`tab-panel-${tab.id}`}
            data-tab={tab.id}
            class={`tab-btn flex-shrink-0 px-5 py-2.5 rounded-xl font-medium text-sm transition-all duration-300 whitespace-nowrap ${
              i === 0
                ? 'bg-primary text-on-primary editorial-shadow'
                : 'text-on-surface-variant hover:text-primary hover:bg-surface-container'
            }`}
          >
            {tab.label}
          </button>
        ))}
      </div>
    </div>
  </div>


  <!-- ═══════════════════════════════════════
       TAB PANELS
  ═══════════════════════════════════════ -->
  <main>
    {tabs.map((tab, tIdx) => (
      <div
        id={`tab-panel-${tab.id}`}
        role="tabpanel"
        aria-labelledby={`tab-btn-${tab.id}`}
        class={`tab-panel ${tIdx !== 0 ? 'hidden' : ''}`}
      >
        {tab.sections.map((section, sIdx) => (
          <section
            class={`py-16 ${sIdx % 2 === 0 ? 'bg-surface-container-low' : 'bg-surface'}`}
            aria-label={section.category}
          >
            <div class="max-w-4xl mx-auto px-6 md:px-8">

              <!-- Section header -->
              <div class="flex items-center gap-4 mb-10">
                <div class="w-10 h-10 rounded-xl bg-primary-container flex items-center justify-center flex-shrink-0">
                  <span class="material-symbols-outlined text-primary text-xl">{section.icon}</span>
                </div>
                <h2 class="font-headline text-3xl md:text-4xl italic text-primary">{section.category}</h2>
                <div class="flex-1 h-px bg-outline-variant/25 ml-2 hidden sm:block"></div>
              </div>

              <!-- Items grid — 2 cols on md+ for shorter sections -->
              <div class={`${section.items.length > 5 ? 'grid grid-cols-1 md:grid-cols-2 gap-x-12' : ''}`}>
                {section.items.map((item, iIdx) => (
                  <div
                    class={`group flex items-baseline justify-between gap-4 py-4 ${
                      iIdx < section.items.length - 1 ? 'border-b border-outline-variant/20' : ''
                    }`}
                  >
                    <span class="font-body text-on-surface group-hover:text-tertiary transition-colors duration-300 leading-snug">
                      {item.name}
                    </span>
                    <span class="text-tertiary font-semibold text-sm whitespace-nowrap flex-shrink-0 tabular-nums">
                      {item.price}
                    </span>
                  </div>
                ))}
              </div>

            </div>
          </section>
        ))}
      </div>
    ))}
  </main>


  <!-- ═══════════════════════════════════════
       FOOTER CTA
  ═══════════════════════════════════════ -->
  <section class="py-12 md:py-20 bg-surface-container-highest text-center fade-in-section" aria-label="Call to action">
    <div class="max-w-2xl mx-auto px-6 md:px-8">
      <div class="font-script text-5xl text-primary mb-4">Come hungry. Leave happy.</div>
      <p class="text-on-surface-variant leading-relaxed mb-8">
        Open every day from 7 am to 3 pm at 2650 SW Wilshire Blvd, Burleson, TX.<br />
        Walk-ins always welcome.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 bg-primary text-on-primary px-8 py-3 rounded-xl font-medium editorial-shadow hover:opacity-85 transition-opacity duration-300"
        >
          <span class="material-symbols-outlined text-base">event_available</span>
          Reserve a Table
        </a>
        <a
          href="tel:6827301391"
          class="inline-flex items-center justify-center gap-2 border-2 border-primary text-primary px-8 py-3 rounded-xl font-medium hover:bg-primary hover:text-on-primary transition-all duration-300"
        >
          <span class="material-symbols-outlined text-base">call</span>
          (682) 730-1391
        </a>
      </div>
    </div>
  </section>

</Layout>


<style>
  /* Smooth panel reveal on tab switch */
  @keyframes panelFadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .tab-panel:not(.hidden) {
    animation: panelFadeIn 0.3s ease-out;
  }

  /* Hide scrollbar on tab strip (mobile) */
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const panels  = document.querySelectorAll<HTMLElement>('.tab-panel');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.tab;

      // Update buttons
      buttons.forEach((b) => {
        const active = b.dataset.tab === target;
        b.setAttribute('aria-selected', String(active));
        b.classList.toggle('bg-primary',        active);
        b.classList.toggle('text-on-primary',   active);
        b.classList.toggle('editorial-shadow',  active);
        b.classList.toggle('text-on-surface-variant', !active);
        b.classList.toggle('hover:text-primary',      !active);
        b.classList.toggle('hover:bg-surface-container', !active);
      });

      // Show / hide panels
      panels.forEach((panel) => {
        const show = panel.id === `tab-panel-${target}`;
        panel.classList.toggle('hidden', !show);
      });

      // Scroll to top of menu content smoothly
      document.getElementById(`tab-panel-${target}`)
        ?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
</script>
