---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Order Cancelled — Burleson Brunch House"
  description="Your order was not completed. Return to the order page to try again."
>

  <div class="min-h-screen flex items-center justify-center px-6 py-24 bg-surface" style="padding-top: 120px;">
    <div class="max-w-md w-full text-center">

      <!-- Icon -->
      <div class="w-20 h-20 rounded-full bg-surface-container-highest flex items-center justify-center mx-auto mb-8 editorial-shadow">
        <span class="material-symbols-outlined text-on-surface-variant text-4xl">shopping_bag</span>
      </div>

      <h1 class="font-headline text-3xl italic text-on-surface mb-3">No worries — order not placed.</h1>
      <p class="text-on-surface-variant leading-relaxed mb-8">
        Your payment was cancelled and nothing was charged. Head back to your order whenever you're ready.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/order"
          class="inline-flex items-center justify-center gap-2 bg-primary text-on-primary px-8 py-3 rounded-xl font-medium text-sm editorial-shadow hover:opacity-85 transition-opacity duration-300"
        >
          <span class="material-symbols-outlined text-base">arrow_back</span>
          Back to Order
        </a>
        <a
          href="tel:6827301391"
          class="inline-flex items-center justify-center gap-2 border-2 border-primary text-primary px-8 py-3 rounded-xl font-medium text-sm hover:bg-primary hover:text-on-primary transition-all duration-300"
        >
          <span class="material-symbols-outlined text-base">call</span>
          Call Us Instead
        </a>
      </div>

    </div>
  </div>

</Layout>
