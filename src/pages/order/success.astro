---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';

const token      = import.meta.env.CLOVER_API_TOKEN  as string | undefined;
const merchantId = import.meta.env.CLOVER_MERCHANT_ID as string | undefined;
const base       = import.meta.env.CLOVER_ENV === 'sandbox'
  ? 'https://sandbox.dev.clover.com'
  : 'https://api.clover.com';

const { searchParams } = Astro.url;
const name    = searchParams.get('name') ?? 'there';
const encoded = searchParams.get('o');

// Push the order to the Clover POS terminal so the kitchen sees it immediately
if (encoded && token && merchantId) {
  try {
    interface OrderItem { name: string; price: number; qty: number; }
    const { name: customerName, phone, notes, items } = JSON.parse(
      Buffer.from(encoded, 'base64url').toString()
    ) as { name: string; phone: string; notes: string; items: OrderItem[] };

    const noteLines = [
      `Online Pickup — ${customerName} — ${phone}`,
      notes ? `Notes: ${notes}` : '',
    ].filter(Boolean).join('\n');

    const orderRes = await fetch(`${base}/v3/merchants/${merchantId}/orders`, {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${token}`,
        'Content-Type':  'application/json',
      },
      body: JSON.stringify({ state: 'open', note: noteLines }),
    });

    if (orderRes.ok) {
      const { id: orderId } = await orderRes.json();

      // Add each item to the ticket — qty > 1 adds duplicate lines (standard POS behaviour)
      for (const item of items) {
        for (let i = 0; i < item.qty; i++) {
          await fetch(`${base}/v3/merchants/${merchantId}/orders/${orderId}/line_items`, {
            method: 'POST',
            headers: {
              'Authorization': `Bearer ${token}`,
              'Content-Type':  'application/json',
            },
            body: JSON.stringify({
              name:     item.name,
              price:    Math.round(item.price * 100),
              unitQty:  1000,
            }),
          });
        }
      }
    }
  } catch (e) {
    // POS push failed — payment was still successful, staff can see it in Clover dashboard
    console.error('Clover POS order creation failed:', e);
  }
}
---

<Layout
  title="Order Confirmed — Burleson Brunch House"
  description="Your pickup order at Burleson Brunch House has been placed and paid. We'll have it ready for you!"
>

  <div class="min-h-screen flex items-center justify-center px-6 py-24 bg-surface" style="padding-top: 120px;">
    <div class="max-w-md w-full text-center">

      <!-- Check icon -->
      <div class="w-20 h-20 rounded-full bg-primary flex items-center justify-center mx-auto mb-8 editorial-shadow">
        <span
          class="material-symbols-outlined text-on-primary text-4xl"
          style="font-variation-settings: 'FILL' 1;"
        >check_circle</span>
      </div>

      <!-- Script accent -->
      <div class="font-script text-5xl text-primary mb-3">Order Confirmed!</div>

      <h1 class="font-headline text-2xl italic text-on-surface mb-2">
        Thank you, {name}! Your order is confirmed.
      </h1>
      <p class="text-on-surface-variant leading-relaxed mb-8" id="confirm-body">
        We'll have everything hot and ready for your pickup time. See you soon!
      </p>

      <!-- Info card -->
      <div class="bg-surface-container-highest rounded-2xl p-6 editorial-shadow mb-8 text-left space-y-4">
        <div class="flex items-start gap-3">
          <span class="material-symbols-outlined text-tertiary text-lg mt-0.5">location_on</span>
          <div>
            <p class="font-semibold text-on-surface text-sm">Pick up at</p>
            <p class="text-on-surface-variant text-sm">2650 SW Wilshire Blvd, Burleson, TX</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="material-symbols-outlined text-tertiary text-lg mt-0.5">timer</span>
          <div>
            <p class="font-semibold text-on-surface text-sm">Your order will be ready</p>
            <p class="text-on-surface-variant text-sm" id="confirm-time">In about 30 minutes</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="material-symbols-outlined text-tertiary text-lg mt-0.5">call</span>
          <div>
            <p class="font-semibold text-on-surface text-sm">Need to make a change?</p>
            <a href="tel:6827301391" class="text-primary text-sm hover:underline">(682) 730-1391</a>
          </div>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 bg-primary text-on-primary px-8 py-3 rounded-xl font-medium text-sm editorial-shadow hover:opacity-85 transition-opacity duration-300"
        >
          <span class="material-symbols-outlined text-base">home</span>
          Back to Home
        </a>
        <a
          href="/menu"
          class="inline-flex items-center justify-center gap-2 border-2 border-primary text-primary px-8 py-3 rounded-xl font-medium text-sm hover:bg-primary hover:text-on-primary transition-all duration-300"
        >
          View Menu
        </a>
      </div>

    </div>
  </div>

</Layout>

<script>
  // Show estimated ready time calculated client-side
  const ready    = new Date(Date.now() + 30 * 60 * 1000);
  const readyStr = ready.toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' });
  const timeEl   = document.getElementById('confirm-time');
  const bodyEl   = document.getElementById('confirm-body');
  if (timeEl) timeEl.textContent = `Around ${readyStr}`;
  if (bodyEl) bodyEl.textContent = `We'll have everything hot and ready for you around ${readyStr}. See you soon!`;
</script>
